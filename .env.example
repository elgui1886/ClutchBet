# ── OpenAI / LLM ──────────────────────────────────────────────

# GitHub Personal Access Token (required)
# Generate at: https://github.com/settings/tokens
OPENAI_API_KEY=

# GitHub Models API base URL (for text/vision models)
OPENAI_BASE_URL=

# Model for text and vision analysis (optional, defaults to gpt-4o)
OPENAI_MODEL=

# Modello che non usa github copilot ma openapi (con credito API di OpenAI)
# https://platform.openai.com/settings/organization/limits
# OPENAI_API_KEY=

# 
# OPENAI_BASE_URL=

# 
# OPENAI_MODEL=

# ── Telegram ──────────────────────────────────────────────────

# Telegram Client API credentials
# Get api_id and api_hash from: https://my.telegram.org → API development tools
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Telegram session string (generated by running: npx tsx src/setup-telegram.ts)
TELEGRAM_SESSION=

# ── Sports Data ───────────────────────────────────────────────

# API-Football key (optional — without it, mock fixtures are used for development)
# Get it at: https://www.api-football.com/ (free tier: 100 requests/day)
FOOTBALL_API_KEY=

# ── Daemon ────────────────────────────────────────────────────

# Cron schedule for daily content generation (optional, default: every day at 08:00)
# Format: standard cron (minute hour day month weekday)
# Timezone: Europe/Rome
# DAEMON_CONTENT_CRON=0 8 * * *
