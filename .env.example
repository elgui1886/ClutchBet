# GitHub Personal Access Token (required)
# Generate at: https://github.com/settings/tokens
OPENAI_API_KEY=ghp-your-github-pat-here

# GitHub Models API base URL (for text/vision models)
OPENAI_BASE_URL=https://models.inference.ai.azure.com

# Model for text and vision analysis (optional, defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Telegram Client API credentials
# Get api_id and api_hash from: https://my.telegram.org → API development tools
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Telegram session string (generated by running: npx tsx src/setup-telegram.ts)
TELEGRAM_SESSION=

# Dashboard credentials
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin
DASHBOARD_SECRET=change-me-to-a-random-string
DASHBOARD_PORT=3000
